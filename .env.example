# Copy to .env and fill in. The producers/consumers read these at runtime.

# Kafka bootstrap servers.
#   - Host processes (producers, local pyspark): localhost:9092
#   - Processes running INSIDE the spark containers: kafka:29092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Free API token from https://cryptopanic.com/developers/api/
CRYPTOPANIC_TOKEN=

# Storage overrides (optional)
FEATURES_DIR=./data/features
CHECKPOINT_DIR=./data/checkpoints
MODEL_PATH=./models/lstm_volatility.pt
